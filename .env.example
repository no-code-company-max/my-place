# Copiar a .env.local (gitignored). Ver docs/stack.md § "Variables de entorno".

# ─── Supabase ─────────────────────────────────────────────────────────────────
# En dev local (supabase start) estos valores los imprime el CLI.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase local (default): postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ─── Stripe ───────────────────────────────────────────────────────────────────
# En dev: usar claves de test (sk_test_...). En prod: live keys.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000
