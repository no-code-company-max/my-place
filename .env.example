# Copiar a .env.local (gitignored). Ver docs/stack.md § "Variables de entorno".
# Trabajamos contra el proyecto de DESARROLLO en Supabase Cloud (ver .glados/supabase-projects.json).

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → Data API (URL) y API Keys.
# ANON_KEY: key "publishable" (sb_publishable_...) o legacy anon JWT. Safe para bundle cliente.
# SERVICE_ROLE_KEY: secret server-side. Nunca exponerla al cliente.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → Database → Connection string (URI).
# La "Database password" se setea/resetea en esa misma página.
#
# DATABASE_URL → pooler (Supavisor) transaction mode, puerto 6543. Ideal para runtime
#                serverless (Vercel, edge, route handlers). `pgbouncer=true` se conserva
#                por compatibilidad histórica — `pg` lo ignora pero algunas tools (psql,
#                Supabase CLI) lo siguen usando como signal.
# DIRECT_URL   → session mode del pooler, puerto 5432. Usado por Prisma para migraciones
#                (que requieren una conexión dedicada sin multiplexing).
#
# El parámetro `connection_limit` del query string YA NO APLICA. Después de la migración
# a `@prisma/adapter-pg` (driver adapter in-process), el pool de conexiones se configura
# en `src/db/client.ts` via la env var `PG_POOL_MAX`:
#  - default 1: cada lambda hold 1 conexión (serverless-safe).
#  - dev local (no serverless): subir a `PG_POOL_MAX=10` en .env.local para paralelismo
#    real cuando el código dispara queries con Promise.all.
DATABASE_URL=postgresql://postgres.<project-ref>:[PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<project-ref>:[PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres
# PG_POOL_MAX=10  # opcional, dev local; default 1 cubre serverless

# ─── Stripe ───────────────────────────────────────────────────────────────────
# En dev: claves de test (sk_test_...). En prod: live keys. Opcionales hasta que se
# conecte billing; serverEnv las marca como `.optional()`.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# ─── Resend (mailer primario) ─────────────────────────────────────────────────
# Dashboard → https://resend.com/api-keys
# En dev local sin `RESEND_API_KEY`, el mailer cae a FakeMailer (loguea a stdout
# y guarda el último email en globalThis para debug). En prod las 3 son
# obligatorias — el boot falla si faltan.
#
# EMAIL_FROM: debe usar un dominio VERIFICADO en Resend (SPF + DKIM + DMARC).
# Ej: "Place <hola@place.community>".
#
# RESEND_WEBHOOK_SECRET: `whsec_...` generado al crear el endpoint en
# Resend dashboard → Webhooks. Usado para verificar firmas svix en
# /api/webhooks/resend.
#
# Supabase Auth (magic link de login) NO usa esta config — la SMTP de
# Supabase se configura en su propio dashboard (Auth → SMTP Settings) con
# una API key dedicada de Resend. Ver `docs/gotchas/supabase-smtp-resend.md`.
RESEND_API_KEY=
EMAIL_FROM="Place <hola@place.community>"
RESEND_WEBHOOK_SECRET=

# ─── Edit session token ───────────────────────────────────────────────────────
# HMAC secret para firmar tokens de sesión de edición (post/comment). Permite
# que una edición abierta dentro de los 60s se guarde aunque el user tarde
# unos segundos más (ventana de gracia: 5min desde abrir el form).
# Mínimo 32 chars. Generar con: `openssl rand -base64 48`.
# En prod es obligatoria; en dev el código cae a un placeholder warn-only.
APP_EDIT_SESSION_SECRET=

# ─── E2E test secret ──────────────────────────────────────────────────────────
# Gate del endpoint `POST /api/test/sign-in` (login programático para Playwright).
# El endpoint devuelve 404 en `NODE_ENV === 'production'` y 404 si el header
# `x-test-secret` no coincide con este valor. Mínimo 24 chars.
# Generar con: `openssl rand -hex 32`. Requerido para correr la suite E2E.
E2E_TEST_SECRET=
