// Schema base del core de Place. Ver `docs/data-model.md`.
// Cada feature agrega sus propias tablas respetando este core.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  displayName String
  handle      String?  @unique
  avatarUrl   String?
  createdAt   DateTime @default(now())

  memberships    Membership[]
  ownedPlaces    PlaceOwnership[]
  posts          Post[]           @relation("PostAuthor")
  comments       Comment[]        @relation("CommentAuthor")
  reactions      Reaction[]
  postReads      PostRead[]
  flagsFiled     Flag[]           @relation("FlagReporter")
  flagsReviewed  Flag[]           @relation("FlagReviewer")
  eventsAuthored Event[]          @relation("EventAuthor")
  eventRsvps     EventRSVP[]

  libraryContributions        LibraryCategoryContributor[]   @relation("LibraryContributor")
  libraryContributionsInvited LibraryCategoryContributor[]   @relation("LibraryContributorInvitedBy")
  libraryItemsAuthored        LibraryItem[]                  @relation("LibraryItemAuthor")
  // G.1 (2026-05-04): completion privada por user + scope de lectura por user.
  libraryItemCompletions      LibraryItemCompletion[]        @relation("LibraryItemCompletion")
  libraryCategoryReadScopes   LibraryCategoryUserReadScope[] @relation("LibraryCategoryUserReadScope")

  // Tier-memberships: ambas direcciones (asignaciones recibidas + asignaciones hechas).
  tierMemberships         TierMembership[] @relation("TierMembershipsAsUser")
  tierMembershipsAssigned TierMembership[] @relation("TierMembershipsAssigned")

  // Permission groups (plan permission-groups G.x):
  //   groupMemberships         → grupos a los que pertenece este user.
  //   groupMembershipsAddedBy  → asignaciones que ESTE user hizo (audit).
  //   membershipsBlockedBy     → memberships que ESTE user bloqueó.
  //   membershipsExpelledBy    → memberships que ESTE user expulsó.
  groupMemberships        GroupMembership[] @relation("GroupMembershipsAsUser")
  groupMembershipsAddedBy GroupMembership[] @relation("GroupMembershipsAddedBy")
  membershipsBlockedBy    Membership[]      @relation("MembershipsBlockedBy")
  membershipsExpelledBy   Membership[]      @relation("MembershipsExpelledBy")

  // Index para `searchMembers` con ILIKE (M.1, plan TierMemberships).
  // Sin él, ILIKE hace full-table-scan; con 150 miembros × N places escala mal.
  @@index([displayName])
}

model Place {
  id          String  @id @default(cuid())
  slug        String  @unique // inmutable una vez creado (multi-tenancy.md)
  name        String
  description String?

  themeConfig  Json @default("{}")
  openingHours Json @default("{}")

  billingMode          BillingMode
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripeConnectId      String?

  enabledFeatures Json @default("[\"conversations\",\"events\",\"members\"]")

  createdAt  DateTime  @default(now())
  archivedAt DateTime?

  memberships Membership[]
  ownerships  PlaceOwnership[]
  invitations Invitation[]
  posts       Post[]
  comments    Comment[]
  reactions   Reaction[]
  openings    PlaceOpening[]
  flags       Flag[]
  events      Event[]

  libraryCategories LibraryCategory[]
  libraryItems      LibraryItem[]
  tiers             Tier[]
  tierMemberships   TierMembership[]
  permissionGroups  PermissionGroup[]
  groupMemberships  GroupMembership[]
}

model Membership {
  id               String    @id @default(cuid())
  userId           String
  placeId          String
  joinedAt         DateTime  @default(now())
  leftAt           DateTime?
  // Timestamp de aplicación del job de erasure 365d (C.L). NULL = nunca
  // procesada. Lo escribe `runErasure` cuando la membership cumple 365d
  // desde `leftAt`. Sirve como idempotency guard.
  erasureAppliedAt DateTime?

  // Block / unblock (delegable vía permiso members:block — plan G.x).
  // Soft-block: membership persiste pero gate `(gated)/layout.tsx`
  // rechaza acceso al place mientras blockedAt IS NOT NULL.
  // contactEmail se usa en `<UserBlockedView>` para que el bloqueado
  // pueda contactar al admin que bloqueó.
  blockedAt           DateTime?
  blockedByUserId     String?
  blockedReason       String?   @db.VarChar(500)
  blockedContactEmail String?

  // Expel (owner-only hardcoded — plan G.x). Setea leftAt + estos campos.
  // Distingue voluntary leave (expelledByUserId IS NULL) de expel
  // (expelledByUserId IS NOT NULL).
  expelledByUserId  String?
  expelReason       String? @db.VarChar(500)
  expelContactEmail String?

  user       User  @relation(fields: [userId], references: [id])
  place      Place @relation(fields: [placeId], references: [id])
  blockedBy  User? @relation("MembershipsBlockedBy", fields: [blockedByUserId], references: [id], onDelete: SetNull)
  expelledBy User? @relation("MembershipsExpelledBy", fields: [expelledByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, placeId])
  @@index([placeId])
}

model PlaceOwnership {
  id        String   @id @default(cuid())
  userId    String
  placeId   String
  grantedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  place Place @relation(fields: [placeId], references: [id])

  @@unique([userId, placeId])
  @@index([placeId])
}

model Invitation {
  id         String    @id @default(cuid())
  placeId    String
  email      String
  invitedBy  String
  asAdmin    Boolean   @default(false)
  asOwner    Boolean   @default(false)
  acceptedAt DateTime?
  expiresAt  DateTime
  token      String    @unique

  // Delivery tracking (ver docs/plans/2026-04-20-members-email-resend.md).
  // `deliveryStatus` evoluciona: PENDING → SENT → (DELIVERED | BOUNCED | COMPLAINED)
  // o PENDING → FAILED si el mailer falla en el send inicial. `providerMessageId`
  // correlaciona con los webhooks de Resend. `lastSentAt` permite rate-limitar el
  // botón de Reenviar desde UI.
  deliveryStatus    InvitationDeliveryStatus @default(PENDING)
  providerMessageId String?
  lastDeliveryError String?
  lastSentAt        DateTime?

  place Place @relation(fields: [placeId], references: [id])
  // Unique parcial `WHERE "acceptedAt" IS NULL` sobre (placeId, lower(email))
  // está definido en la migración 20260420000000_members_invitation_fields.
  // Prisma no soporta expresar índices parciales declarativamente — ver docs/features/members/spec.md.

  @@index([placeId])
  @@index([email])
  @@index([providerMessageId])
}

enum InvitationDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  BOUNCED
  COMPLAINED
  FAILED
}

enum BillingMode {
  OWNER_PAYS
  OWNER_PAYS_AND_CHARGES
  SPLIT_AMONG_MEMBERS
}

// Slice `discussions` (Fase 5). Ver docs/features/discussions/spec.md § 4.

model Post {
  id             String    @id @default(cuid())
  placeId        String
  authorUserId   String?
  authorSnapshot Json
  title          String    @db.VarChar(160)
  slug           String    @db.VarChar(180)
  body           Json?
  createdAt      DateTime  @default(now())
  editedAt       DateTime?
  hiddenAt       DateTime?
  lastActivityAt DateTime  @default(now())
  version        Int       @default(0)

  place       Place        @relation(fields: [placeId], references: [id], onDelete: Restrict)
  author      User?        @relation("PostAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  comments    Comment[]
  reads       PostRead[]
  // Back-reference 1:1 al evento que generó este Post como thread asociado
  // (auto-thread, ver docs/features/events/spec-integrations.md § 1). Nullable
  // porque la mayoría de los Posts no son de evento. El @unique vive en Event.postId.
  event       Event?
  // Back-reference 1:1 al item de biblioteca cuando este Post es un thread
  // documento (R.7.5+). Nullable. El @unique vive en LibraryItem.postId. La
  // exclusividad con `event` (un Post no puede ser simultáneamente Event e
  // Item) se valida en domain layer (createEventAction + createItemAction).
  libraryItem LibraryItem?
  // Índice parcial en migración discussions_core (Prisma no soporta WHERE):
  //   (authorUserId) WHERE authorUserId IS NOT NULL

  @@unique([placeId, slug])
  @@index([placeId, createdAt(sort: Desc)])
  @@index([placeId, lastActivityAt(sort: Desc)])
}

model Comment {
  id              String    @id @default(cuid())
  postId          String
  placeId         String
  authorUserId    String?
  authorSnapshot  Json
  body            Json
  quotedCommentId String?
  quotedSnapshot  Json?
  createdAt       DateTime  @default(now())
  editedAt        DateTime?
  deletedAt       DateTime?
  version         Int       @default(0)

  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  place         Place     @relation(fields: [placeId], references: [id], onDelete: Restrict)
  author        User?     @relation("CommentAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  quotedComment Comment?  @relation("CommentQuote", fields: [quotedCommentId], references: [id], onDelete: SetNull)
  quotedBy      Comment[] @relation("CommentQuote")
  // Índices parciales en migración: cursor backward y authorUserId.

  @@index([postId, createdAt])
}

model Reaction {
  id         String            @id @default(cuid())
  targetType ContentTargetKind
  targetId   String
  placeId    String
  userId     String
  emoji      ReactionEmoji
  createdAt  DateTime          @default(now())

  place Place @relation(fields: [placeId], references: [id], onDelete: Restrict)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([targetType, targetId, userId, emoji])
  @@index([targetType, targetId])
}

model PlaceOpening {
  id        String             @id @default(cuid())
  placeId   String
  startAt   DateTime
  endAt     DateTime?
  source    PlaceOpeningSource
  createdAt DateTime           @default(now())

  place Place      @relation(fields: [placeId], references: [id], onDelete: Restrict)
  reads PostRead[]
  // UNIQUE parcial `(placeId) WHERE endAt IS NULL` en migración: máx 1 apertura activa por place.

  @@index([placeId, startAt(sort: Desc)])
}

model PostRead {
  id             String   @id @default(cuid())
  postId         String
  userId         String
  placeOpeningId String
  readAt         DateTime @default(now())
  dwellMs        Int

  post    Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  opening PlaceOpening @relation(fields: [placeOpeningId], references: [id], onDelete: Restrict)

  @@unique([postId, userId, placeOpeningId])
  @@index([postId, placeOpeningId])
  @@index([userId, postId])
}

model Flag {
  id                  String            @id @default(cuid())
  targetType          ContentTargetKind
  targetId            String
  placeId             String
  // Reporter denormalizado siguiendo el patrón Post/Comment/Event:
  //  - `reporterUserId` nullable + FK SetNull → erasure 365d setea NULL.
  //  - `reporterSnapshot` siempre poblado: al crear refleja el viewer; en
  //    erasure 365d se reescribe a `{ displayName: 'ex-miembro' }`.
  // La UI del admin queue lee de `reporterSnapshot`, no del User join.
  reporterUserId      String?
  reporterSnapshot    Json
  reason              FlagReason
  reasonNote          String?           @db.VarChar(500)
  status              FlagStatus        @default(OPEN)
  createdAt           DateTime          @default(now())
  reviewedAt          DateTime?
  reviewerAdminUserId String?
  reviewNote          String?           @db.VarChar(500)

  place    Place @relation(fields: [placeId], references: [id], onDelete: Restrict)
  reporter User? @relation("FlagReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)
  reviewer User? @relation("FlagReviewer", fields: [reviewerAdminUserId], references: [id], onDelete: SetNull)

  @@unique([targetType, targetId, reporterUserId])
  @@index([placeId, status, createdAt(sort: Desc)])
}

enum ContentTargetKind {
  POST
  COMMENT
  EVENT
}

enum ReactionEmoji {
  THUMBS_UP
  HEART
  LAUGH
  PRAY
  THINKING
  CRY
}

enum PlaceOpeningSource {
  SCHEDULED
  ALWAYS_OPEN
  EXCEPTION
}

enum FlagReason {
  SPAM
  HARASSMENT
  OFFTOPIC
  MISINFO
  OTHER
}

enum FlagStatus {
  OPEN
  REVIEWED_ACTIONED
  REVIEWED_DISMISSED
}

// Audit trail del job de erasure 365d (C.L). Cada run del job inserta
// una fila por membership procesada, capturando los snapshots `authorSnapshot`
// ANTES de sobrescribir con "ex-miembro". Permite rollback manual via SQL
// si se detecta bug en `leftAt` o ejecución prematura. RLS deny-all por
// default (sin policies): solo service_role puede leer/escribir.
//
// Ver `docs/decisions/2026-04-24-erasure-365d.md`.
model ErasureAuditLog {
  id              String   @id @default(cuid())
  membershipId    String
  userId          String
  placeId         String
  postIds         String[]
  commentIds      String[]
  // Array<{ type: 'POST'|'COMMENT', id, displayName, avatarUrl: string | null }>
  // Shape exacto validable desde TS; no constraint a nivel DB (Json genérico
  // por simplicidad del rollback manual).
  snapshotsBefore Json
  appliedAt       DateTime @default(now())
  // True cuando el run fue con `?dryRun=true` — la tx rollbackeó los UPDATEs
  // pero el insert queda. Permite inspeccionar qué HABRÍA hecho el job.
  dryRun          Boolean  @default(false)
  // Null si la tx committed exitosa. String si hubo error y se capturó
  // fuera de la tx (la fila NO se escribe si la tx rollbackea — esto solo
  // aplica a errores post-commit del job orchestrator).
  error           String?

  @@index([membershipId])
  @@index([appliedAt])
}

// Slice `events` (Fase 6 — F.B). Ver docs/features/events/spec.md § 4.
//
// Decisiones encodeadas en el schema:
//   1. `authorUserId` nullable + `authorSnapshot jsonb` → erasure 365d (mismo patrón Post/Comment).
//   2. `postId` nullable + `@unique` → 1:1 con el thread asociado (auto-thread tx atómica).
//      Nullable resuelve el chicken-and-egg al crear (Event → Post → UPDATE postId
//      en una sola tx). `onDelete: SetNull` permite que el Post desaparezca sin
//      arrastrar el evento. Defensivo a futuro: discussions deshabilitada por place.
//   3. `cancelledAt` para soft-cancel — preserva RSVPs como señal histórica + thread
//      sigue vivo. DELETE prohibido para authenticated (RLS); service_role bypassea.
//   4. `startsAt`/`endsAt` como `timestamptz` UTC + `timezone TEXT` IANA — eventos
//      son puntos en tiempo (vs hours = patterns recurrentes en local-place).
//   5. `description Json?` reusa TipTap AST de discussions.
//   6. `EventRSVP.note` válido sólo en GOING_CONDITIONAL/NOT_GOING_CONTRIBUTING vía
//      CHECK constraint en la migración (defensa en profundidad sobre el invariant).
//   7. `EventRSVP.userId` cascadea a User para que el DELETE explícito por erasure
//      365d (PR-3 en F.C) tenga relación natural; el filtro per-place en runErasure
//      asegura que sólo se borran las RSVPs del place que el user dejó.
//
// Las políticas RLS viven en la misma migración (events_core_schema). El enum
// EVENT en `ContentTargetKind` se agrega en una segunda migración separada por
// la restricción Postgres `ALTER TYPE ... ADD VALUE` fuera de tx.
model Event {
  id             String    @id @default(cuid())
  placeId        String
  authorUserId   String?
  authorSnapshot Json
  title          String    @db.VarChar(120)
  description    Json?
  startsAt       DateTime  @db.Timestamptz(3)
  endsAt         DateTime? @db.Timestamptz(3)
  timezone       String
  location       String?   @db.VarChar(200)
  postId         String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  cancelledAt    DateTime?

  place  Place       @relation(fields: [placeId], references: [id], onDelete: Restrict)
  author User?       @relation("EventAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  post   Post?       @relation(fields: [postId], references: [id], onDelete: SetNull)
  rsvps  EventRSVP[]

  @@index([placeId, startsAt])
  @@index([placeId, cancelledAt, startsAt])
}

model EventRSVP {
  id        String    @id @default(cuid())
  eventId   String
  userId    String
  state     RSVPState
  // Sólo válido en GOING_CONDITIONAL y NOT_GOING_CONTRIBUTING (CHECK constraint).
  // Documentado en docs/features/events/spec-rsvp.md § 2.
  note      String?   @db.VarChar(280)
  updatedAt DateTime  @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId, state])
}

enum RSVPState {
  GOING
  GOING_CONDITIONAL
  NOT_GOING_CONTRIBUTING
  NOT_GOING
}

// =============================================================================
// LIBRARY (R.7)
// =============================================================================
//
// Slice de biblioteca: categorías curadas por el admin que agrupan items
// editoriales (thread documentos). Ver docs/features/library/spec.md.
//
// R.7.1: solo categorías + contributors. Items (LibraryItem) se suman en
// R.7.5 como FK opcional desde Post (Post.libraryItemId).

enum ContributionPolicy {
  DESIGNATED
  MEMBERS_OPEN
  SELECTED_GROUPS
}

// G.1 (2026-05-04): tipo de categoría — `GENERAL` (default, content
// regular) o `COURSE` (items dentro pueden declarar prereqs y los
// viewers pueden marcarlos como completados). Ver
// `docs/decisions/2026-05-04-library-courses-and-read-access.md`.
enum LibraryCategoryKind {
  GENERAL
  COURSE
}

// G.1 (2026-05-04): discriminator del scope de lectura. `PUBLIC` =
// cualquier miembro activo lee (default, alineado con principio "calmo
// y abierto"). `GROUPS|TIERS|USERS` = sólo quien matchea el set
// correspondiente lee. Las 3 tablas read scope (LibraryCategoryGroupReadScope,
// LibraryCategoryTierReadScope, LibraryCategoryUserReadScope) son
// independientes — sólo aplica la que corresponde al `kind` actual.
enum LibraryReadAccessKind {
  PUBLIC
  GROUPS
  TIERS
  USERS
}

model LibraryCategory {
  id                 String                @id @default(cuid())
  placeId            String
  slug               String // auto desde title; inmutable post-create
  emoji              String
  title              String                @db.VarChar(60)
  // Orden manual del admin (drag & drop en R.7.3). NULL = "sin posición";
  // queries ordenan COALESCE(position, MAX+1) → createdAt como fallback.
  position           Int?
  contributionPolicy ContributionPolicy    @default(MEMBERS_OPEN)
  // G.1 (2026-05-04): tipo de categoría. Default GENERAL — el flag
  // COURSE es opt-in del owner cuando crea/edita la categoría.
  kind               LibraryCategoryKind   @default(GENERAL)
  // G.1 (2026-05-04): discriminator del read access scope. Default PUBLIC.
  readAccessKind     LibraryReadAccessKind @default(PUBLIC)
  archivedAt         DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  place           Place                           @relation(fields: [placeId], references: [id], onDelete: Cascade)
  contributors    LibraryCategoryContributor[]
  items           LibraryItem[]
  // GroupCategoryScope (plan permission-groups G.x): grupos cuyos
  // permisos library:* están scopados a esta categoría.
  groupScopes     GroupCategoryScope[]
  // G.1 (2026-05-04): read scopes por tipo (groups | tiers | users).
  // Sólo aplica el set que corresponde al `readAccessKind` actual.
  readGroupScopes LibraryCategoryGroupReadScope[]
  readTierScopes  LibraryCategoryTierReadScope[]
  readUserScopes  LibraryCategoryUserReadScope[]

  @@unique([placeId, slug])
  @@index([placeId, archivedAt])
  @@index([placeId, position])
}

// G.1 (2026-05-04): scope de lectura por permission group. Cuando
// `LibraryCategory.readAccessKind === 'GROUPS'`, sólo users con
// `GroupMembership` a alguno de estos grupos pueden leer items de la
// categoría. ON DELETE CASCADE de ambos lados — borrar el grupo o la
// categoría limpia el scope.
model LibraryCategoryGroupReadScope {
  categoryId String
  groupId    String

  category LibraryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  group    PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([categoryId, groupId])
  @@index([groupId])
}

// G.1 (2026-05-04): scope de lectura por tier. Mismo patrón que
// GroupReadScope. Cuando `readAccessKind === 'TIERS'`, sólo users con
// `TierMembership` activa a alguno de estos tiers leen.
model LibraryCategoryTierReadScope {
  categoryId String
  tierId     String

  category LibraryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tier     Tier            @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@id([categoryId, tierId])
  @@index([tierId])
}

// G.1 (2026-05-04): scope de lectura por usuario individual. Mismo
// patrón. Cuando `readAccessKind === 'USERS'`, sólo los users listados
// leen. Útil para casos puntuales (ej: contenido para un consultor).
model LibraryCategoryUserReadScope {
  categoryId String
  userId     String

  category LibraryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user     User            @relation("LibraryCategoryUserReadScope", fields: [userId], references: [id], onDelete: Cascade)

  @@id([categoryId, userId])
  @@index([userId])
}

model LibraryCategoryContributor {
  categoryId      String
  userId          String
  invitedByUserId String
  invitedAt       DateTime @default(now())

  category  LibraryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user      User            @relation("LibraryContributor", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User            @relation("LibraryContributorInvitedBy", fields: [invitedByUserId], references: [id], onDelete: NoAction)

  @@id([categoryId, userId])
  @@index([userId])
}

// LibraryItem (R.7.5): el thread documento. 1:1 con Post.
//
// `placeId` denormalizado para que la RLS no haga JOIN en cada SELECT.
// La app garantiza que coincide con Post.placeId (insert atómico en
// R.7.6). `categoryId` ON DELETE Restrict — categorías solo se archivan
// (soft), nunca se DELETE físicamente. `postId` ON DELETE Cascade —
// si el Post desaparece, el item se va con él.
model LibraryItem {
  id             String    @id @default(cuid())
  placeId        String
  categoryId     String
  postId         String    @unique
  // Author denormalizado para que la RLS de UPDATE sea sin sub-query
  // (mismo precedente que Event.authorUserId). Nullable: ON DELETE
  // SET NULL del User → erasure 365d compatible. La app garantiza que
  // LibraryItem.authorUserId === Post.authorUserId al crear.
  authorUserId   String?
  // Snapshot del autor poblado al crear y reescrito a 'ex-miembro' por
  // erasure 365d. La UI lee de acá para mostrar nombre/avatar (mismo
  // patrón Post/Comment/Event).
  authorSnapshot Json
  // Cover opcional. Mobile no renderiza; reservado para layout desktop.
  coverUrl       String?
  // G.1 (2026-05-04): prereq opcional para items en categorías kind=COURSE.
  // Self-FK al item que el viewer debe haber completado para poder abrir
  // este. Single id en v1 (no DAG) — si aparece la necesidad de múltiples
  // prereqs por item, se evoluciona a tabla aparte sin migración destructiva.
  // ON DELETE SET NULL: si se borra el prereq, los items que lo referenciaban
  // quedan sin prereq (no fallan). Validación de ciclos en app-layer (BFS).
  prereqItemId   String?
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  place       Place                   @relation(fields: [placeId], references: [id], onDelete: Cascade)
  category    LibraryCategory         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  post        Post                    @relation(fields: [postId], references: [id], onDelete: Cascade)
  author      User?                   @relation("LibraryItemAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  prereq      LibraryItem?            @relation("LibraryItemPrereq", fields: [prereqItemId], references: [id], onDelete: SetNull)
  prereqOf    LibraryItem[]           @relation("LibraryItemPrereq")
  completions LibraryItemCompletion[]

  @@index([placeId, archivedAt])
  @@index([categoryId, archivedAt])
  @@index([prereqItemId])
}

// G.1 (2026-05-04): tracking privado de completion por usuario. Cuando
// el viewer marca un item como completado (botón explícito, no auto-detect),
// insertamos una row. El uniqueness `(itemId, userId)` garantiza idempotencia.
// El owner puede ver completions agregadas (admin only); peers nunca.
// Sin métricas públicas, sin %, sin badges (CLAUDE.md "sin gamificación").
model LibraryItemCompletion {
  itemId      String
  userId      String
  completedAt DateTime @default(now())

  item LibraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User        @relation("LibraryItemCompletion", fields: [userId], references: [id], onDelete: Cascade)

  @@id([itemId, userId])
  @@index([userId])
}

// Segmentos de membresía del place (definición + visibilidad). v1 sólo entrega
// la primitiva — sin pagos, sin TierMembership, sin paywall. Owner-only CRUD,
// gateado a nivel app (server actions con findPlaceOwnership + UI gate). RLS
// se suma con el plan unificado posterior. Ver docs/features/tiers/spec.md y
// docs/decisions/2026-05-02-tier-model.md.
//
// **Partial unique index NO reflejado acá** (Prisma no lo soporta declarativo):
//   `Tier_placeId_lowerName_published_unique`
//   ON "Tier" ("placeId", LOWER("name"))
//   WHERE "visibility" = 'PUBLISHED'
// Garantiza máx 1 tier PUBLISHED por (placeId, name) case-insensitive.
// Definido en migration `20260502010000_tier_published_name_unique`.
// Las server actions catchean P2002 sobre este index y lo mapean a un
// return discriminated union `{ ok: false, error: 'name_already_published' }`.
model Tier {
  id          String         @id @default(cuid())
  placeId     String
  name        String         @db.VarChar(60)
  description String?        @db.VarChar(280)
  // 0 = gratis. Cap defensivo en Zod (max 999_999 = $9,999.99) — DB acepta más
  // por si el cap sube cuando llegue Stripe.
  priceCents  Int
  currency    String         @default("USD") @db.VarChar(3)
  duration    TierDuration
  // Tiers nuevos arrancan ocultos. Owner los publica explícitamente.
  visibility  TierVisibility @default(HIDDEN)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  place             Place                          @relation(fields: [placeId], references: [id], onDelete: Cascade)
  tierMemberships   TierMembership[]
  // G.1 (2026-05-04): scope de lectura library por tier — relación inversa.
  libraryReadScopes LibraryCategoryTierReadScope[]

  @@index([placeId, visibility])
  @@index([placeId, createdAt])
}

// Asignación de un Tier a un User dentro de un Place. Asignación manual
// owner-only en v1 (sin Stripe). Cardinalidad N: un user puede tener N tiers
// asignados simultáneamente (e.g., free + premium). `@@unique([tierId, userId])`
// previene duplicados del mismo tier.
//
// Audit log preservado vía snapshot pattern (mismo de Post/Comment/Flag/Event):
//   `assignedByUserId` nullable + `onDelete: SetNull` + `assignedBySnapshot Json`
//   con `{ displayName, avatarUrl }` congelado al momento de asignar.
//   Sobrevive aunque el assigner pase por erasure 365d.
//
// Ver `docs/features/tier-memberships/spec.md` y
// `docs/decisions/2026-05-02-tier-memberships-model.md`.
model TierMembership {
  id                 String    @id @default(cuid())
  tierId             String
  userId             String
  placeId            String
  assignedAt         DateTime  @default(now())
  // FK al user que asignó. Nullable + `onDelete: SetNull` para que el row
  // sobreviva si el assigner pasa por erasure 365d. El snapshot de abajo
  // preserva el dato histórico (displayName, avatar al momento de asignar).
  assignedByUserId   String?
  // Snapshot JSON: { displayName: string, avatarUrl: string | null }.
  // Patrón canónico — ver `docs/decisions/2026-04-24-erasure-365d.md`.
  assignedBySnapshot Json
  // NULL = indefinido (vive hasta que owner remueva). Si presente, calculado
  // de `assignedAt + tierDurationToDays(tier.duration)` al asignar. v1 sólo
  // lo guarda informativo; cron de expiración + paywall llegan en Fase 3.
  expiresAt          DateTime?
  // Defensive future-proofing: Stripe v3 trackeará renovaciones aquí.
  updatedAt          DateTime  @updatedAt

  tier       Tier  @relation(fields: [tierId], references: [id], onDelete: Restrict)
  user       User  @relation("TierMembershipsAsUser", fields: [userId], references: [id], onDelete: Cascade)
  place      Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("TierMembershipsAssigned", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@unique([tierId, userId])
  @@index([placeId, userId])
  @@index([placeId, tierId])
  @@index([expiresAt])
}

enum TierDuration {
  SEVEN_DAYS
  FIFTEEN_DAYS
  ONE_MONTH
  THREE_MONTHS
  SIX_MONTHS
  ONE_YEAR
}

enum TierVisibility {
  PUBLISHED
  HIDDEN
}

// Sistema de permisos delegables del plan permission-groups (G.x).
//
// Owner crea grupos custom con permisos atómicos (10 permisos enumerados
// en `groups/domain/permissions.ts`). Asigna miembros a grupos. Cada
// miembro hereda los permisos de los grupos a los que pertenece (union).
//
// Grupo preset "Administradores" (isPreset=true) auto-generado por place
// con TODOS los permisos. Reemplaza el rol ADMIN legacy (columna
// `Membership.role` + enum eliminados en C.3 del plan permission-groups).
//
// Owner es dios implícito: hardcoded `if (isOwner) return true` en
// `hasPermission` (members slice). Owner NO necesita estar en grupos.
//
// Library tiene scope por categoría: si un grupo tiene entries en
// GroupCategoryScope, sus permisos library:* aplican SOLO a esas
// categorías. Sin entries → global.
//
// Ver:
//   docs/features/groups/spec.md
//   docs/decisions/2026-05-02-permission-groups-model.md
//   docs/plans/2026-05-02-permission-groups-and-member-controls.md
model PermissionGroup {
  id          String   @id @default(cuid())
  placeId     String
  name        String   @db.VarChar(60)
  description String?  @db.VarChar(280)
  // Postgres array (text[]) de permisos atómicos. Validados Zod en
  // server actions contra el enum hardcoded `Permission`. Pragmático
  // para 10 permisos estables; si crece > 30, NORMALIZAR a tabla
  // GroupPermission(groupId, permission) con FK al enum (ADR aparte).
  permissions String[]
  // Hardcoded preset "Administradores": NO se puede eliminar
  // (deleteGroupAction lo bloquea con cannot_delete_preset). NO se
  // pueden modificar permisos del preset (cannot_modify_preset). Sí
  // se pueden gestionar miembros + cambiar name/description.
  isPreset    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  place             Place                           @relation(fields: [placeId], references: [id], onDelete: Cascade)
  groupMemberships  GroupMembership[]
  categoryScopes    GroupCategoryScope[]
  // G.1 (2026-05-04): scope de lectura library por grupo — relación inversa.
  libraryReadScopes LibraryCategoryGroupReadScope[]

  @@index([placeId])
}

// Asignación N:M de User a PermissionGroup. Audit log via `addedByUserId`
// (snapshot pattern NO se aplica aquí v1 — accept overhead de perder info
// si el assigner pasa por erasure 365d).
model GroupMembership {
  id            String   @id @default(cuid())
  groupId       String
  userId        String
  // placeId denormalizado para queries por place sin join (hasPermission).
  placeId       String
  addedAt       DateTime @default(now())
  addedByUserId String?

  group   PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User            @relation("GroupMembershipsAsUser", fields: [userId], references: [id], onDelete: Cascade)
  place   Place           @relation(fields: [placeId], references: [id], onDelete: Cascade)
  addedBy User?           @relation("GroupMembershipsAddedBy", fields: [addedByUserId], references: [id], onDelete: SetNull)

  @@unique([groupId, userId])
  @@index([placeId, userId])
  @@index([userId])
}

// Scope library: si un grupo tiene entries acá, sus permisos library:*
// aplican SOLO a esas categorías. Sin entries → global.
//
// Hardcoded check: el grupo preset "Administradores" NO puede tener
// scope (setGroupCategoryScopeAction lo bloquea con cannot_scope_preset).
model GroupCategoryScope {
  groupId    String
  categoryId String

  group    PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  category LibraryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([groupId, categoryId])
  @@index([categoryId])
}
