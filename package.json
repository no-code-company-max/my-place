{
  "name": "place",
  "version": "0.1.0",
  "private": true,
  "description": "Un lugar digital pequeño e íntimo para hasta 150 personas.",
  "engines": {
    "node": "24.x",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "next dev",
    "build": "cross-env NODE_ENV=production next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "dotenv -e .env.local -- playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:e2e:seed": "dotenv -e .env.local -- tsx tests/fixtures/e2e-seed.ts",
    "test:rls": "dotenv -e .env.local -- vitest run --config vitest.rls.config.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:new": "dotenv -e .env.local -- prisma migrate diff --from-migrations ./prisma/migrations --to-schema-datamodel prisma/schema.prisma --script",
    "prisma:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "prisma:migrate:status": "dotenv -e .env.local -- prisma migrate status",
    "prisma:studio": "dotenv -e .env.local -- prisma studio",
    "perf": "dotenv -e .env.local -- tsx scripts/perf/measure-perf.ts",
    "prisma:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "prepare": "husky",
    "ci": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@lexical/clipboard": "^0.44.0",
    "@lexical/link": "^0.44.0",
    "@lexical/list": "^0.44.0",
    "@lexical/react": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@lexical/selection": "^0.44.0",
    "@lexical/utils": "^0.44.0",
    "@prisma/adapter-pg": "5.22.0",
    "@prisma/client": "5.22.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@react-email/render": "^2.0.7",
    "@supabase/ssr": "0.10.2",
    "@supabase/supabase-js": "2.103.3",
    "framer-motion": "^11",
    "frimousse": "^0.3.0",
    "lexical": "^0.44.0",
    "lucide-react": "^1.11.0",
    "next": "15.5.15",
    "pg": "^8.20.0",
    "pino": "10.3.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.72.1",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "stripe": "22.0.2",
    "svix": "^1.91.1",
    "zod": "4.3.6",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/eslintrc": "3.3.5",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "20.19.39",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/ui": "4.1.4",
    "autoprefixer": "10.5.0",
    "cross-env": "7.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.15",
    "husky": "9.1.7",
    "jsdom": "29.0.2",
    "lint-staged": "16.4.0",
    "pino-pretty": "13.1.3",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.6.14",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.19",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.2",
    "vitest": "4.1.4"
  }
}
